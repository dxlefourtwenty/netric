[Unit]
Description=Netric FastAPI backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/ec2-user/netric/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ec2-user/netric/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
